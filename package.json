{
  "name": "agent-kit",
  "version": "0.1.0",
  "description": "Multi-model CLI agent framework — configure .agent/config.toml and go",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/main.js"
  },
  "bin": {
    "agent-kit": "dist/main.js",
    "agent": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/main.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)}\" && chmod +x dist/main.js",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench",
    "benchmark": "tsx tests/benchmark/run.ts",
    "benchmark:compare": "tsx tests/benchmark/run.ts --compare",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "cli",
    "multi-model",
    "framework"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxiaoqi/agent-kit.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ansi-escapes": "^7.3.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "commander": "^12.0.0",
    "figures": "^6.1.0",
    "ink": "^5.2.1",
    "marked": "^15.0.12",
    "openai": "^4.28.0",
    "ora": "^8.0.1",
    "react": "^18.3.1",
    "toml": "^3.0.0",
    "wrap-ansi": "^9.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.28",
    "concurrently": "^9.2.1",
    "create-vite": "^9.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}
